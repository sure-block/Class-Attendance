<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ClasslandAttendance.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ClasslandAttendance.Models"
    xmlns:views="using:ClasslandAttendance.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <views:CountToStringConverter x:Key="CountConverter"/>
        <views:StringToVisibilityConverter x:Key="StringToVisConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="20">
        <StackPanel Spacing="20">

            <!-- ── 名单管理 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="名单管理" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 添加成员 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:ConnectionId='55' Grid.Column="0"
                                 PlaceholderText="输入姓名"
                                                                                     />
                        <Button x:ConnectionId='56' Grid.Column="2"
                                Content="添加"
                                                                             
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <!-- 名单列表 -->
                    <ListBox x:ConnectionId='49'                                                          
                                                                                          
                             MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate                      >
                                <TextBlock x:ConnectionId='54'                 Padding="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button x:ConnectionId='50' Content="删除选中"
                                                                            
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>

                    <!-- 导入和清空 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:ConnectionId='51' Grid.Column="0"
                                Content="从TXT导入名单"
                                                                                
                                HorizontalAlignment="Stretch"/>
                        <Button x:ConnectionId='52' Grid.Column="2"
                                Content="清空名单"
                                                                               
                                HorizontalAlignment="Stretch"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 日志查看 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="日志查看" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 日志文件选择 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:ConnectionId='46' Grid.Column="0"
                                  PlaceholderText="选择日志文件（留空=全部）"
                                                                                            
                                                                                                
                                  HorizontalAlignment="Stretch"/>
                        <Button x:ConnectionId='47' Grid.Column="2"
                                Content="载入"
                                                                                   />
                        <Button x:ConnectionId='48' Grid.Column="4"
                                Content="刷新文件列表"
                                                             />
                    </Grid>

                    <!-- 筛选条件 -->
                    <Expander Header="筛选条件" HorizontalAlignment="Stretch">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:ConnectionId='44' Grid.Column="0"
                                         Header="按姓名筛选"
                                         PlaceholderText="留空=全部"
                                                                                          />
                                <ComboBox x:ConnectionId='45' Grid.Column="2"
                                          Header="按操作类型筛选"
                                          PlaceholderText="全部"
                                                                                                        
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="" Tag=""/>
                                    <ComboBoxItem Content="签到"/>
                                    <ComboBoxItem Content="取消签到"/>
                                </ComboBox>
                            </Grid>
                            <StackPanel Grid.Row="2" Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CalendarDatePicker x:ConnectionId='42' Grid.Column="0"
                                                        Header="开始日期"
                                                        PlaceholderText="选择日期"
                                                                                                              
                                                        HorizontalAlignment="Stretch"/>
                                    <CalendarDatePicker x:ConnectionId='43' Grid.Column="2"
                                                        Header="结束日期"
                                                        PlaceholderText="选择日期"
                                                                                                            
                                                        HorizontalAlignment="Stretch"/>
                                </Grid>
                                <Button x:ConnectionId='41' Content="应用筛选"
                                                                                       
                                        Style="{ThemeResource AccentButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Expander>

                    <!-- 日志表格 -->
                    <TextBlock x:ConnectionId='33'                                                                                                      
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ListView x:ConnectionId='34'                                                            
                              MaxHeight="300"
                              SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="操作" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="姓名" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="时间" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="状态" FontWeight="SemiBold" FontSize="12"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate                                  >
                                <Grid x:ConnectionId='36' Padding="12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:ConnectionId='37' Grid.Column="0"                           FontSize="13"/>
                                    <TextBlock x:ConnectionId='38' Grid.Column="1"                      FontSize="13"/>
                                    <TextBlock x:ConnectionId='39' Grid.Column="2"                      FontSize="13"/>
                                    <TextBlock x:ConnectionId='40' Grid.Column="3"                        FontSize="13"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- ── 统计分析 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="统计分析" FontSize="16" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:ConnectionId='30' Grid.Column="0"
                                 Header="查询姓名"
                                 PlaceholderText="输入姓名"
                                                                                 />
                        <TextBox x:ConnectionId='31' Grid.Column="2"
                                 Header="迟到阈值 (HH:mm:ss)"
                                 PlaceholderText="09:00:00"
                                                                                     />
                        <Button x:ConnectionId='32' Grid.Column="4"
                                Content="查询"
                                VerticalAlignment="Bottom"
                                                                              
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <Border x:ConnectionId='28' CornerRadius="8" Padding="16"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                                                                                     >
                        <TextBlock x:ConnectionId='29'                                                   
                                   TextWrapping="Wrap" FontFamily="Consolas" FontSize="13"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── 迟到查询 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="迟到查询" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 姓名筛选 -->
                    <TextBox x:ConnectionId='15' Header="按姓名筛选（留空=查询所有人）"
                             PlaceholderText="输入姓名"
                                                                                 />

                    <!-- 日期范围 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CalendarDatePicker x:ConnectionId='24' Grid.Column="0"
                                            Header="开始日期"
                                                                                                     
                                            HorizontalAlignment="Stretch"/>
                        <CalendarDatePicker x:ConnectionId='25' Grid.Column="2"
                                            Header="结束日期"
                                                                                                   
                                            HorizontalAlignment="Stretch"/>
                        <TextBox x:ConnectionId='26' Grid.Column="4"
                                 Header="迟到阈值 (HH:mm:ss)"
                                 PlaceholderText="09:00:00"
                                                                                     />
                        <Button x:ConnectionId='27' Grid.Column="6"
                                Content="查询"
                                VerticalAlignment="Bottom"
                                                                                    
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <TextBlock x:ConnectionId='16'                                                                                                    
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ListView x:ConnectionId='17'                                                          
                              MaxHeight="300"
                              SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="姓名" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="时间" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="日期" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="日志文件" FontWeight="SemiBold" FontSize="12"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate                               >
                                <Grid x:ConnectionId='19' Padding="12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:ConnectionId='20' Grid.Column="0"                      FontSize="13"/>
                                    <TextBlock x:ConnectionId='21' Grid.Column="1"                      FontSize="13"/>
                                    <TextBlock x:ConnectionId='22' Grid.Column="2"                             FontSize="13"/>
                                    <TextBlock x:ConnectionId='23' Grid.Column="3"                          FontSize="13" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- ── 最早签到查询 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="最早签到查询" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 人数限制 -->
                    <TextBox x:ConnectionId='2' Header="人数限制（每个日志取前N人，0=不限制）"
                             PlaceholderText="0"
                                                                                         />

                    <!-- 日期范围 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CalendarDatePicker x:ConnectionId='12' Grid.Column="0"
                                            Header="开始日期"
                                                                                                         
                                            HorizontalAlignment="Stretch"/>
                        <CalendarDatePicker x:ConnectionId='13' Grid.Column="2"
                                            Header="结束日期"
                                                                                                       
                                            HorizontalAlignment="Stretch"/>
                        <Button x:ConnectionId='14' Grid.Column="4"
                                Content="查询"
                                VerticalAlignment="Bottom"
                                                                                         
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <TextBlock x:ConnectionId='3'                                                                                                         
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ListView x:ConnectionId='4'                                                               
                              MaxHeight="300"
                              SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="姓名" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="时间" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="日期" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="日志文件" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="4" Text="次数" FontWeight="SemiBold" FontSize="12"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate                                    >
                                <Grid x:ConnectionId='6' Padding="12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:ConnectionId='7' Grid.Column="0"                      FontSize="13"/>
                                    <TextBlock x:ConnectionId='8' Grid.Column="1"                      FontSize="13"/>
                                    <TextBlock x:ConnectionId='9' Grid.Column="2"                             FontSize="13"/>
                                    <TextBlock x:ConnectionId='10' Grid.Column="3"                          FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:ConnectionId='11' Grid.Column="4"                       FontSize="13" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

