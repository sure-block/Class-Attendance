<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClasslandAttendance.Views.AttendancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ClasslandAttendance.Models"
    xmlns:views="using:ClasslandAttendance.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <views:DateTimeToTimeConverter x:Key="TimeConverter"/>
        <views:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <!-- 左侧：计数 + 操作 -->
            <ColumnDefinition Width="200"/>
            <!-- 分隔线 -->
            <ColumnDefinition Width="1"/>
            <!-- 右侧：已签到/未签到列表 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 左侧面板 ── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 签到计数 -->
            <Border Grid.Row="0" CornerRadius="12" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Margin="0,0,12,16">
                <StackPanel>
                    <TextBlock Text="签到进度" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{x:Bind ViewModel.CountText, Mode=OneWay}"
                               FontSize="36" FontWeight="Bold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- 停止/重新签到按钮 -->
            <Button Grid.Row="1" x:Name="StopButton"
                    Content="{x:Bind ViewModel.StopButtonText, Mode=OneWay}"
                    Click="StopButton_Click"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,12,8"
                    Style="{ThemeResource AccentButtonStyle}"/>

            <!-- 状态提示 -->
            <Border Grid.Row="2" CornerRadius="8" Padding="12,8"
                    Margin="0,0,12,0"
                    Visibility="{x:Bind ViewModel.IsStopped, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                    Background="#FFF4CE">
                <TextBlock Text="⚠ 签到已停止，继续签到将标记为 false"
                           TextWrapping="Wrap" FontSize="12"
                           Foreground="#7A4B00"/>
            </Border>
        </Grid>

        <!-- 分隔线 -->
        <Rectangle Grid.Column="1"
                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                   Margin="0,0,0,0"/>

        <!-- ── 右侧面板 ── -->
        <Grid Grid.Column="2" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 已签到 -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <FontIcon Glyph="&#xE8FB;" FontSize="14"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                              Margin="0,0,6,0"/>
                    <TextBlock Text="已签到" FontWeight="SemiBold" FontSize="14"/>
                </StackPanel>
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.CheckedInList, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Person">
                            <Grid Padding="8,6" CornerRadius="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                           VerticalAlignment="Center" FontSize="14"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind CheckInTime, Converter={StaticResource TimeConverter}}"
                                           FontSize="12" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="8,0"/>
                                <Button Grid.Column="2"
                                        Tag="{x:Bind}"
                                        Click="CancelCheckIn_Click"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Padding="4"
                                        ToolTipService.ToolTip="取消签到">
                                    <FontIcon Glyph="&#xE711;" FontSize="12"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Rectangle Grid.Row="1"
                       Height="1"
                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                       Margin="0,4"/>

            <!-- 未签到 -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <FontIcon Glyph="&#xEA3A;" FontSize="14"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Margin="0,0,6,0"/>
                    <TextBlock Text="未签到" FontWeight="SemiBold" FontSize="14"/>
                </StackPanel>
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.NotCheckedInList, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Person">
                            <Grid Padding="8,6" CornerRadius="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                           VerticalAlignment="Center" FontSize="14"/>
                                <Button Grid.Column="1"
                                        Tag="{x:Bind}"
                                        Click="CheckIn_Click"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Padding="4"
                                        ToolTipService.ToolTip="签到">
                                    <FontIcon Glyph="&#xE73E;" FontSize="12"
                                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
