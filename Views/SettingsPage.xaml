<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ClasslandAttendance.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ClasslandAttendance.Models"
    xmlns:views="using:ClasslandAttendance.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <views:CountToStringConverter x:Key="CountConverter"/>
        <views:StringToVisibilityConverter x:Key="StringToVisConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="20">
        <StackPanel Spacing="20">

            <!-- ── 名单管理 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="名单管理" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 添加成员 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 PlaceholderText="输入姓名"
                                 Text="{x:Bind ViewModel.NewPersonName, Mode=TwoWay}"/>
                        <Button Grid.Column="2"
                                Content="添加"
                                Command="{x:Bind ViewModel.AddPersonCommand}"
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <!-- 名单列表 -->
                    <ListBox ItemsSource="{x:Bind ViewModel.RosterItems, Mode=OneWay}"
                             SelectedItem="{x:Bind ViewModel.SelectedPerson, Mode=TwoWay}"
                             MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" Padding="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="删除选中"
                            Command="{x:Bind ViewModel.RemovePersonCommand}"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>

                    <!-- 导入和清空 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="从TXT导入名单"
                                Command="{x:Bind ViewModel.ImportRosterCommand}"
                                HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="2"
                                Content="清空名单"
                                Command="{x:Bind ViewModel.ClearRosterCommand}"
                                HorizontalAlignment="Stretch"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 日志查看 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="日志查看" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 日志文件选择 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  PlaceholderText="选择日志文件（留空=全部）"
                                  ItemsSource="{x:Bind ViewModel.LogFileNames, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedLogFile, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="2"
                                Content="载入"
                                Command="{x:Bind ViewModel.LoadSelectedLogCommand}"/>
                        <Button Grid.Column="4"
                                Content="刷新文件列表"
                                Click="RefreshLogFiles_Click"/>
                    </Grid>

                    <!-- 筛选条件 -->
                    <Expander Header="筛选条件" HorizontalAlignment="Stretch">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Header="按姓名筛选"
                                         PlaceholderText="留空=全部"
                                         Text="{x:Bind ViewModel.FilterName, Mode=TwoWay}"/>
                                <ComboBox Grid.Column="2"
                                          Header="按操作类型筛选"
                                          PlaceholderText="全部"
                                          SelectedItem="{x:Bind ViewModel.FilterOperation, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="" Tag=""/>
                                    <ComboBoxItem Content="签到"/>
                                    <ComboBoxItem Content="取消签到"/>
                                </ComboBox>
                            </Grid>
                            <StackPanel Grid.Row="2" Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CalendarDatePicker Grid.Column="0"
                                                        Header="开始日期"
                                                        PlaceholderText="选择日期"
                                                        Date="{x:Bind ViewModel.FilterDateStart, Mode=TwoWay}"
                                                        HorizontalAlignment="Stretch"/>
                                    <CalendarDatePicker Grid.Column="2"
                                                        Header="结束日期"
                                                        PlaceholderText="选择日期"
                                                        Date="{x:Bind ViewModel.FilterDateEnd, Mode=TwoWay}"
                                                        HorizontalAlignment="Stretch"/>
                                </Grid>
                                <Button Content="应用筛选"
                                        Command="{x:Bind ViewModel.ApplyFilterCommand}"
                                        Style="{ThemeResource AccentButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Expander>

                    <!-- 日志表格 -->
                    <TextBlock Text="{x:Bind ViewModel.DisplayedLogs.Count, Mode=OneWay, Converter={StaticResource CountConverter}}"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ListView ItemsSource="{x:Bind ViewModel.DisplayedLogs, Mode=OneWay}"
                              MaxHeight="300"
                              SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="操作" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="姓名" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="时间" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="状态" FontWeight="SemiBold" FontSize="12"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AttendanceLog">
                                <Grid Padding="12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Operation}" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Time}" FontSize="13"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind Status}" FontSize="13"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- ── 统计分析 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="统计分析" FontSize="16" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Header="查询姓名"
                                 PlaceholderText="输入姓名"
                                 Text="{x:Bind ViewModel.StatsName, Mode=TwoWay}"/>
                        <TextBox Grid.Column="2"
                                 Header="迟到阈值 (HH:mm:ss)"
                                 PlaceholderText="09:00:00"
                                 Text="{x:Bind ViewModel.LateThreshold, Mode=TwoWay}"/>
                        <Button Grid.Column="4"
                                Content="查询"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.QueryStatsCommand}"
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <Border CornerRadius="8" Padding="16"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            Visibility="{x:Bind ViewModel.StatsResult, Mode=OneWay, Converter={StaticResource StringToVisConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.StatsResult, Mode=OneWay}"
                                   TextWrapping="Wrap" FontFamily="Consolas" FontSize="13"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── 迟到查询 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="迟到查询" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 姓名筛选 -->
                    <TextBox Header="按姓名筛选（留空=查询所有人）"
                             PlaceholderText="输入姓名"
                             Text="{x:Bind ViewModel.LateQueryName, Mode=TwoWay}"/>

                    <!-- 日期范围 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CalendarDatePicker Grid.Column="0"
                                            Header="开始日期"
                                            Date="{x:Bind ViewModel.LateQueryDateStart, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch"/>
                        <CalendarDatePicker Grid.Column="2"
                                            Header="结束日期"
                                            Date="{x:Bind ViewModel.LateQueryDateEnd, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch"/>
                        <TextBox Grid.Column="4"
                                 Header="迟到阈值 (HH:mm:ss)"
                                 PlaceholderText="09:00:00"
                                 Text="{x:Bind ViewModel.LateThreshold, Mode=TwoWay}"/>
                        <Button Grid.Column="6"
                                Content="查询"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.QueryLateRecordsCommand}"
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <TextBlock Text="{x:Bind ViewModel.LateRecords.Count, Mode=OneWay, Converter={StaticResource CountConverter}}"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ListView ItemsSource="{x:Bind ViewModel.LateRecords, Mode=OneWay}"
                              MaxHeight="300"
                              SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="姓名" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="时间" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="日期" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="日志文件" FontWeight="SemiBold" FontSize="12"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:LateRecord">
                                <Grid Padding="12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Time}" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind DateDisplay}" FontSize="13"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind FileName}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- ── 最早签到查询 ── -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="最早签到查询" FontSize="16" FontWeight="SemiBold"/>

                    <!-- 人数限制 -->
                    <TextBox Header="人数限制（每个日志取前N人，0=不限制）"
                             PlaceholderText="0"
                             Text="{x:Bind ViewModel.EarliestQueryTopCount, Mode=TwoWay}"/>

                    <!-- 日期范围 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CalendarDatePicker Grid.Column="0"
                                            Header="开始日期"
                                            Date="{x:Bind ViewModel.EarliestQueryDateStart, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch"/>
                        <CalendarDatePicker Grid.Column="2"
                                            Header="结束日期"
                                            Date="{x:Bind ViewModel.EarliestQueryDateEnd, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="4"
                                Content="查询"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.QueryEarliestCheckInsCommand}"
                                Style="{ThemeResource AccentButtonStyle}"/>
                    </Grid>

                    <TextBlock Text="{x:Bind ViewModel.EarliestCheckIns.Count, Mode=OneWay, Converter={StaticResource CountConverter}}"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <ListView ItemsSource="{x:Bind ViewModel.EarliestCheckIns, Mode=OneWay}"
                              MaxHeight="300"
                              SelectionMode="None">
                        <ListView.Header>
                            <Grid Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="姓名" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="时间" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="日期" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="3" Text="日志文件" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Grid.Column="4" Text="次数" FontWeight="SemiBold" FontSize="12"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:EarliestCheckIn">
                                <Grid Padding="12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Time}" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind DateDisplay}" FontSize="13"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind FileName}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="4" Text="{x:Bind Count}" FontSize="13" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
